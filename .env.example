# ============================================
# LINEARVOICE ENVIRONMENT CONFIGURATION
# ============================================

# Upstash Redis (Required - for event streaming and state)
# Create Redis at https://upstash.com/console/redis
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Kapso WhatsApp API
# Get these from https://kapso.dev
KAPSO_API_BASE=https://api.kapso.io
KAPSO_AUTH_TOKEN=your_kapso_auth_token_here
KAPSO_PHONE_ID=your_phone_number_id_here
KAPSO_WEBHOOK_TOKEN=your_webhook_verification_token

# Linear API Integration
# Get API key from https://linear.app/settings/api
LINEAR_API_KEY=lin_api_your_key_here
LINEAR_WORKSPACE_ID=your_workspace_slug

# ElevenLabs Voice API (Optional - for voice features)
# Sign up at https://elevenlabs.io/
ELEVENLABS_API_KEY=sk_your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# AI Configuration
# Option 1: Use Vercel AI Gateway (recommended)
AI_GATEWAY_API_KEY=your_ai_gateway_key_optional

# Option 2: Use Anthropic directly (fallback)
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# Webhook verification
WEBHOOK_SECRET=your-secure-webhook-secret-32-chars-min

# Feature flags
ENABLE_VOICE=true
ENABLE_REDIS_PERSISTENCE=true

# Environment
NODE_ENV=development
LOG_LEVEL=debug
