# LinearVoice - WhatsApp to Linear AI Agent

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Kapso WhatsApp API
KAPSO_API_BASE=https://api.kapso.io
KAPSO_AUTH_TOKEN=
KAPSO_PHONE_ID=

# Vercel Chat SDK
CHAT_SDK_API_KEY=

# Linear API & MCP
LINEAR_API_KEY=
LINEAR_MCP_ENABLED=true

# ElevenLabs (Voice)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Webhook verification
WEBHOOK_SECRET=your-secure-webhook-secret

# Feature flags
ENABLE_VOICE=true
ENABLE_REDIS_PERSISTENCE=true

# Environment
NODE_ENV=development
