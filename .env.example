# ============================================
# LINEARVOICE ENVIRONMENT CONFIGURATION
# ============================================
# Track 3 — Vercel Chat SDK Agents

# Upstash Redis (Vercel Marketplace, 1-click) — REQUIRED
# Auto-injected by `vercel integration add upstash/upstash-kv`. Do not
# fill these by hand unless you're paste-importing an existing instance.
KV_REST_API_URL=REPLACE_ME
KV_REST_API_TOKEN=REPLACE_ME
# Read-only token (auto-injected, optional):
# KV_REST_API_READ_ONLY_TOKEN=
# KV_URL=

# REDIS_URL — REQUIRED in production. TCP connection string for
# @chat-adapter/state-redis (the Chat SDK state adapter uses node-redis,
# not the Upstash REST API above). The Vercel Upstash Marketplace
# integration auto-injects this name. Without it the bot falls back to
# per-instance memory state — safe for local dev, but breaks dedupe /
# locks / thread history across Fluid Compute instances in prod.
REDIS_URL=

# AI Gateway — required in production. Locally either of the two works.
# VERCEL_OIDC_TOKEN is auto-populated by `vercel env pull` after `vercel link`.
AI_GATEWAY_API_KEY=
VERCEL_OIDC_TOKEN=

# Kapso (WhatsApp Cloud API proxy) — REQUIRED
KAPSO_API_KEY=REPLACE_ME                  # Bearer token from kapso.ai dashboard
KAPSO_API_BASE=https://api.kapso.ai       # REST API base
KAPSO_GRAPH_API_URL=https://api.kapso.ai  # Graph-API-compatible base used by the adapter
KAPSO_WEBHOOK_SECRET=REPLACE_ME           # Random string; set in Kapso webhook config + here
KAPSO_PHONE_NUMBER_ID=REPLACE_ME          # Phone number ID from Kapso

# Linear — required for the agent to actually create/read issues.
# Agent gracefully degrades to a placeholder reply if missing.
LINEAR_OAUTH_TOKEN=REPLACE_ME             # Personal API key from linear.app/settings/api

# ElevenLabs — required for voice (STT inbound, TTS outbound). Phase-2.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Bot config
BOT_USERNAME=linearvoice

# Environment
NODE_ENV=development
