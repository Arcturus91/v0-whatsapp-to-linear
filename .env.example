# ============================================
# LINEARVOICE ENVIRONMENT CONFIGURATION
# ============================================
# Track 3 — Vercel Chat SDK Agents

# Upstash Redis (Vercel Marketplace, 1-click) — REQUIRED
# Provides REST creds for /api/* routes (events, conversations, …).
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Optional: TCP redis URL (rediss://default:password@host:port) for the
# Chat SDK state-redis adapter. If absent we fall back to memory state.
# REDIS_URL=

# AI Gateway — required in production. Locally either of the two works.
AI_GATEWAY_API_KEY=
# VERCEL_OIDC_TOKEN is auto-populated by `vercel env pull` after `vercel link`.
VERCEL_OIDC_TOKEN=

# Kapso (WhatsApp Cloud API proxy) — REQUIRED
KAPSO_API_KEY=                         # Bearer token from kapso.ai dashboard
KAPSO_API_BASE=https://api.kapso.ai    # REST API base
KAPSO_GRAPH_API_URL=https://api.kapso.ai  # Graph-API-compatible base used by the adapter
KAPSO_WEBHOOK_SECRET=                  # Random string; set in Kapso webhook config + here
KAPSO_PHONE_NUMBER_ID=                 # Phone number ID from Kapso

# Linear (required for the agent to actually work — agent gracefully
# degrades to a placeholder reply if missing).
LINEAR_OAUTH_TOKEN=                    # Personal API key from linear.app/settings/api

# ElevenLabs (required for voice features — STT for inbound, TTS for outbound)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Bot config
BOT_USERNAME=linearvoice

# Environment
NODE_ENV=development
